# Frontend environment variables — localhost / local dev
# Runtime auth config is loaded from the backend `/meta/frontend-config` endpoint.
# This fallback is used to locate the backend when runtime config is requested.

# Use localhost so the app works from a browser on the host (http://localhost:3000).
# Port 4000 is forwarded from the devcontainer; backend and SSR in-container also use this.
NEXT_PUBLIC_SOBA_API_BASE_URL=http://localhost:4000/api/v1