# Frontend environment variables — localhost / local dev
# Runtime auth config is loaded from the backend `/meta/frontend-config` endpoint.
# This fallback is used to locate the backend when runtime config is requested.

# Use localhost so the app works from a browser on the host (http://localhost:3000).
NEXT_PUBLIC_SOBA_API_BASE_URL=http://localhost:4000/api/v1

# Optional: Next.js server only. In Docker Compose use the backend service name, e.g.:
# SOBA_API_INTERNAL_URL=http://backend:4000/api/v1

# Feature allowlist for this frontend deployment (codes from GET /meta/features).
# Also injected into the page at runtime (window.__SOBA_FEATURES_ALLOWED) so Docker images see compose env without rebuilding.
# Use * or all to allow every platform-allowed feature. Empty/unset = none (explicit list or wildcard required).
# Common codes: workspaces, design-mode, submit-mode, meta (meta = optional /meta page for health + API meta JSON).
# Example submit-only: submit-mode
# Example with meta review: workspaces,design-mode,submit-mode,meta
NEXT_PUBLIC_SOBA_FEATURES_ALLOWED=*