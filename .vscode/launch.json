{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "SOBA (Backend + Temporal + Frontend)",
      "configurations": [
        "SOBA Backend",
        "SOBA Temporal Worker",
        "SOBA Frontend"
      ]
    },
    {
      "name": "SOBA (Backend + Temporal)",
      "configurations": [
        "SOBA Backend",
        "SOBA Temporal Worker"
      ]
    }
  ],
  "configurations": [
    {
      "name": "SOBA Backend",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/backend",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "skipFiles": ["<node_internals>/**"],
      "console": "integratedTerminal"
    },
    {
      "name": "SOBA Temporal Worker",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/backend",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["exec", "tsx", "watch", "temporal-worker.ts"],
      "skipFiles": ["<node_internals>/**"],
      "console": "integratedTerminal"
    },
    {
      "name": "SOBA Frontend",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/frontend",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev:watch"],
      "skipFiles": ["<node_internals>/**"],
      "console": "integratedTerminal"
    },
    {
      "name": "SOBA Frontend (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/frontend"
    }
  ]
}
