{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Dev Services: Up",
      "type": "shell",
      "command": "docker compose -f .devcontainer/docker-compose.yml up -d --build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Dev Services: Down",
      "type": "shell",
      "command": "docker compose -f .devcontainer/docker-compose.yml down",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
