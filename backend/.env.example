# trace, debug, info, warn, error, fatal - http / morgan is info level by default
LOG_LEVEL=info


# Form engine plugin (versioned)
FORM_ENGINE_DEFAULT_CODE=formio-v5

# Cache plugin (e.g. cache-memory, cache-redis). Defaults to cache-memory if unset. Plugin-specific: PLUGIN_CACHE_<CODE>_*
CACHE_DEFAULT_CODE=cache-memory

# MessageBus plugin (e.g. messagebus-memory, messagebus-redis). Defaults to messagebus-memory if unset. Plugin-specific: PLUGIN_MESSAGEBUS_<CODE>_*
MESSAGEBUS_DEFAULT_CODE=messagebus-memory

# Form.io v5 plugin config (PLUGIN_FORMIO_V5_* — no legacy FORMIO_* fallback)
PLUGIN_FORMIO_V5_ROUTES_ALLOWED=true
PLUGIN_FORMIO_V5_PROXY_PATH=/formio-v5
PLUGIN_FORMIO_V5_API_BASE_URL=http://localhost:3001
PLUGIN_FORMIO_V5_ADMIN_API_URL=http://localhost:3001
PLUGIN_FORMIO_V5_RENDER_API_URL=http://localhost:3001
PLUGIN_FORMIO_V5_ADMIN_USERNAME=formio@localhost.com
PLUGIN_FORMIO_V5_ADMIN_PASSWORD=formio
# Proxy and routes: set to true to mount Form.io CE proxy at PROXY_PATH (default /formio-v5)
# PLUGIN_FORMIO_V5_ROUTES_ALLOWED=true
# PLUGIN_FORMIO_V5_PROXY_PATH=/formio-v5
# PLUGIN_FORMIO_V5_PROJECT_PATH=
# PLUGIN_FORMIO_V5_VERSION=v5

# Future: formio-v4 side-by-side (same keys, different prefix)
# PLUGIN_FORMIO_V4_API_BASE_URL=
# PLUGIN_FORMIO_V4_ADMIN_API_URL=
# PLUGIN_FORMIO_V4_RENDER_API_URL=
# PLUGIN_FORMIO_V4_ADMIN_USERNAME=
# PLUGIN_FORMIO_V4_ADMIN_PASSWORD=
# PLUGIN_FORMIO_V4_PROJECT_PATH=
# PLUGIN_FORMIO_V4_VERSION=v4

# IdP plugin (same pattern as CACHE_DEFAULT_CODE, FORM_ENGINE_DEFAULT_CODE)
IDP_PLUGIN_DEFAULT_CODE=bcgov-sso

# Default SSO JWT config (BC Gov Keycloak); used by bcgov-sso when PLUGIN_BCGOV_SSO_* not set
IDP_PLUGIN_DEFAULT_SSO_JWKS_URI=https://dev.loginproxy.gov.bc.ca/auth/realms/standard/protocol/openid-connect/certs
IDP_PLUGIN_DEFAULT_SSO_JWT_ISSUER=https://dev.loginproxy.gov.bc.ca/auth/realms/standard
IDP_PLUGIN_DEFAULT_SSO_JWT_AUDIENCE=connected-services-submit-6349

# Optional: multiple IdP plugins (comma-separated, try in order). When unset, uses IDP_PLUGIN_DEFAULT_CODE only
# IDP_PLUGINS=bcgov-sso
# Optional overrides for bcgov-sso: PLUGIN_BCGOV_SSO_JWKS_URI, PLUGIN_BCGOV_SSO_JWT_ISSUER, PLUGIN_BCGOV_SSO_JWT_AUDIENCE
# Optional: idp-github (e.g. GitHub Enterprise). Defaults to https://api.github.com
# PLUGIN_IDP_GITHUB_GITHUB_API_URL=https://api.github.com

# Optional: example JWT for testing
#EXAMPLE_JWT=

# Application
NODE_ENV=development
# Behind one or more reverse proxies (OpenShift ingress, etc.): set hop count. Default 1 when NODE_ENV is not development; development defaults to no trust. Use 0 to force no trust.
# TRUST_PROXY_HOPS=1

# CORS — allowed browser origins (comma-separated). Always an explicit allowlist; never '*'.
# Production: set the deployed frontend origin(s).
# CORS_ORIGIN=https://my-app.example.gov.bc.ca
# Development fallback: used when CORS_ORIGIN is unset and NODE_ENV=development.
CORS_DEV_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Database (workspace-first SOBA core)
# Option 1: full URL (if set, takes precedence over component vars below)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/soba
# Option 2: URL components (used when DATABASE_URL is unset; all five required together)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=soba
DB_ADMIN_DATABASE=postgres
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT_MS=10000
DB_QUERY_TIMEOUT_MS=60000
DB_STATEMENT_TIMEOUT_MS=60000
DB_LOCK_TIMEOUT_MS=10000
DB_MIGRATION_READY_ATTEMPTS=5
DB_MIGRATION_READY_SLEEP_MS=5000

# System user identity: subject for provider=system (seed creates this user). Used to resolve the system actor. Default: soba-system
SOBA_SYSTEM_SUBJECT=soba-system

# Workspace plugin resolver hints
# Enterprise plugin may use these headers from gateway:
# x-enterprise-workspace-id, x-cstar-tenant-id

# Workspace plugins (feature-sliced plugin activation/config)
WORKSPACE_PLUGINS_ALLOWED=enterprise-cstar,personal-local
WORKSPACE_PLUGINS_STRICT_MODE=false

# Enterprise CSTAR plugin config
PLUGIN_ENTERPRISE_CSTAR_HEADER_KEYS=x-enterprise-workspace-id,x-cstar-tenant-id
PLUGIN_ENTERPRISE_CSTAR_REQUIRE_EXTERNAL_HEADER=false

# Personal local plugin config
PLUGIN_PERSONAL_LOCAL_COOKIE_KEY=soba_workspace_id
PLUGIN_PERSONAL_LOCAL_ALLOW_HEADER_OVERRIDE=true

# Temporal.io — when false, the worker exits without connecting; getClient() rejects.
TEMPORAL_ALLOWED=false
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=soba

# Rate limiting (all windows in ms)
# Global: applied to every request
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
# Authenticated API routes (core + admin)
RATE_LIMIT_API_WINDOW_MS=60000
RATE_LIMIT_API_MAX=60
# Public endpoints (health, meta, docs)
RATE_LIMIT_PUBLIC_WINDOW_MS=60000
RATE_LIMIT_PUBLIC_MAX=200


# Storage configuration (for file uploads, etc.)
# Storage profiles: each is a named config for a storage backend (storage-memory, local-storage,
# or s3-compatible), so multiple backends can run at once. List active profiles in STORAGE_PROFILES;
# each uses the prefix STORAGE_PROFILE_<PROFILE>_*. Unset defaults to a single 'default' profile on
# storage-memory.
STORAGE_PROFILES=default

# 'default' profile → storage-memory: in-process, ephemeral, no filesystem or external service.
# Ideal for local dev and ephemeral (PR) environments; NOT durable and NOT shared across replicas.
STORAGE_PROFILE_DEFAULT_BACKEND=storage-memory

# For a filesystem-backed profile instead, switch the backend and set a writable base path:
# STORAGE_PROFILE_DEFAULT_BACKEND=local-storage
# STORAGE_PROFILE_DEFAULT_BASE_PATH=./data/files

# Example second profile → a separate S3/MinIO server. Uncomment and add to STORAGE_PROFILES
# (e.g. STORAGE_PROFILES=default,minio) to enable:
# STORAGE_PROFILE_MINIO_BACKEND=s3-compatible
# STORAGE_PROFILE_MINIO_ENDPOINT=http://localhost
# STORAGE_PROFILE_MINIO_PORT=9000
# STORAGE_PROFILE_MINIO_USE_SSL=false
# STORAGE_PROFILE_MINIO_ACCESS_KEY=minioadmin
# STORAGE_PROFILE_MINIO_SECRET_KEY=minioadminpassword
# STORAGE_PROFILE_MINIO_BUCKET_NAME=soba-bucket

# Max upload size accepted by the files API (feature-level, not per backend).
# FILES_STORAGE_PROFILE determines which profile the /files api uses...
FILES_STORAGE_PROFILE=default
FILES_MAX_FILE_SIZE_MB=10