{
  "name": "@soba/backend",
  "version": "1.0.0",
  "description": "",
  "main": "app.ts",
  "scripts": {
    "test": "NODE_OPTIONS='--max-old-space-size=1024' jest --runInBand",
    "test:parallel": "NODE_OPTIONS='--max-old-space-size=1024' jest --maxWorkers=2",
    "script:test-formio-proxy": "tsx scripts/test-formio-proxy.ts",
    "test:watch": "NODE_OPTIONS='--max-old-space-size=1024' jest --watch --runInBand",
