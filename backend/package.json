    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "type-check": "tsc --noEmit",
    "check": "pnpm type-check && pnpm lint",
    "start": "node dist/src/app.js",
    "temporal-worker": "tsx temporal-worker.ts",
    "temporal-worker:dev": "tsx watch temporal-worker.ts",
    "temporal-worker:start": "node dist/temporal-worker.js"
  },
