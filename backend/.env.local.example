# Local overrides — NEVER commit .env.local
# Copy: cp .env.local.example .env.local
# Overrides .env for secrets, credentials, etc.

# trace, debug, info, warn, error, fatal - http / morgan is info level by default
LOG_LEVEL=info

# Form.io v5 plugin config (local dev)
PLUGIN_FORMIO_V5_ROUTES_ALLOWED=true
PLUGIN_FORMIO_V5_PROXY_PATH=/formio-v5
PLUGIN_FORMIO_V5_API_BASE_URL=http://localhost:3001
PLUGIN_FORMIO_V5_ADMIN_API_URL=http://localhost:3001
PLUGIN_FORMIO_V5_RENDER_API_URL=http://localhost:3001
PLUGIN_FORMIO_V5_ADMIN_USERNAME=formio@localhost.com
PLUGIN_FORMIO_V5_ADMIN_PASSWORD=formio

# Future: formio-v4 side-by-side
# PLUGIN_FORMIO_V4_API_BASE_URL=http://host.docker.internal:3002
# PLUGIN_FORMIO_V4_ADMIN_API_URL=http://host.docker.internal:3002
# PLUGIN_FORMIO_V4_RENDER_API_URL=http://host.docker.internal:3002
# PLUGIN_FORMIO_V4_ADMIN_USERNAME=formio@localhost.com
# PLUGIN_FORMIO_V4_ADMIN_PASSWORD=formio

# Optional: override default SSO JWT config (e.g. different realm)
IDP_PLUGINS=bcgov-sso
# IDP_PLUGIN_DEFAULT_SSO_JWT_AUDIENCE=
# IDP_PLUGIN_DEFAULT_SSO_JWT_ISSUER=
# IDP_PLUGIN_DEFAULT_SSO_JWKS_URI=

# Optional: local plugin overrides
# Cache / messagebus default to in-memory if unset; override for Redis etc.:
# CACHE_DEFAULT_CODE=cache-memory
# MESSAGEBUS_DEFAULT_CODE=messagebus-memory
# Temp storage defaults to tempstorage-os (under os.tmpdir()) if unset:
# TEMPSTORAGE_DEFAULT_CODE=tempstorage-os
# PLUGIN_TEMPSTORAGE_OS_SUBDIR=soba
# PLUGIN_TEMPSTORAGE_MOUNT_DIR=/app/tmp

# Storage configuration (for file uploads, etc.)
# Storage profiles: each is a named config for a storage backend (storage-memory, storage-local,
# or storage-s3), so multiple backends can run at once. List active profiles in STORAGE_PROFILES;
# each uses the prefix STORAGE_PROFILE_<PROFILE>_*. Unset defaults to a single 'default' profile on
# storage-memory.
# STORAGE_PROFILES=default

# 'default' profile → storage-memory: in-process, ephemeral, no filesystem or external service.
# Ideal for local dev and ephemeral (PR) environments; NOT durable and NOT shared across replicas.
# STORAGE_PROFILE_DEFAULT_BACKEND=storage-memory

# For a filesystem-backed profile instead, switch the backend and set a writable base path:
# STORAGE_PROFILE_DEFAULT_BACKEND=storage-local
# STORAGE_PROFILE_DEFAULT_BASE_PATH=./data/files

# Example second profile → a separate S3/MinIO server. Uncomment and add to STORAGE_PROFILES
# (e.g. STORAGE_PROFILES=default,s3) to enable:
# STORAGE_PROFILE_S3_BACKEND=storage-s3
# STORAGE_PROFILE_S3_ENDPOINT=http://localhost
# STORAGE_PROFILE_S3_PORT=9000
# STORAGE_PROFILE_S3_USE_SSL=false
# STORAGE_PROFILE_S3_ACCESS_KEY=minioadmin
# STORAGE_PROFILE_S3_SECRET_KEY=minioadminpassword
# STORAGE_PROFILE_S3_BUCKET_NAME=soba-bucket

# Max upload size accepted by the files API (feature-level, not per backend).
# FILES_STORAGE_PROFILE determines which profile the /files api uses...
# FILES_STORAGE_PROFILE=default
# FILES_MAX_FILE_SIZE_MB=10